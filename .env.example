# PocketBase URL (used by SvelteKit client and server)
PUBLIC_POCKETBASE_URL=http://localhost:8090

# Google Drive Integration (optional)
# Create OAuth2 credentials at https://console.cloud.google.com/apis/credentials
# 1. Create a new project (or select an existing one)
# 2. Enable the Google Drive API in the API Library
# 3. Go to Credentials > Create Credentials > OAuth client ID
# 4. Set the application type to "Web application"
# 5. Add your app's origin as an authorized JavaScript origin
# 6. Set the redirect URI to your app's origin (e.g. http://localhost:3000)
# 7. Copy the Client ID below
PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id-here
# PUBLIC_GOOGLE_API_KEY is no longer needed with the new OAuth2 flow

# PocketBase Encryption Key (for Docker)
# PB_ENCRYPTION_KEY=change-me-to-a-random-string